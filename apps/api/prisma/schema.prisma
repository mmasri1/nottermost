generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String             @id @default(uuid())
  email        String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())

  memberships  WorkspaceMember[]
  sentMessages Message[]
  dmParticipants DmParticipant[]
  channelMemberships ChannelMember[]
  sentChannelMessages ChannelMessage[]
  sentChannelInvites  ChannelInvite[] @relation("ChannelInvitesSent")
  receivedChannelInvites ChannelInvite[] @relation("ChannelInvitesReceived")
}

model Workspace {
  id        String             @id @default(uuid())
  name      String
  createdAt DateTime           @default(now())

  members   WorkspaceMember[]
  threads   DirectThread[] // legacy (1:1 only)
  dmThreads DmThread[]
  channels  Channel[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}

model DirectThread {
  id          String    @id @default(uuid())
  workspaceId String
  userAId     String
  userBId     String
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@unique([workspaceId, userAId, userBId])
}

enum DmThreadKind {
  direct
  group
}

model DmThread {
  id            String       @id @default(uuid())
  workspaceId   String
  kind          DmThreadKind
  name          String?
  createdAt     DateTime     @default(now())

  // For kind=direct, we keep a deterministic pair to ensure uniqueness.
  directUserAId String?
  directUserBId String?

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants  DmParticipant[]
  messages      Message[]

  @@index([workspaceId, createdAt])
  @@unique([workspaceId, directUserAId, directUserBId])
}

model DmParticipant {
  threadId String
  userId   String
  role     String
  joinedAt DateTime @default(now())

  thread   DmThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  thread    DmThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([threadId, createdAt])
}

model Channel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     ChannelMember[]
  invites     ChannelInvite[]
  messages    ChannelMessage[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model ChannelMember {
  channelId String
  userId    String
  role      String
  createdAt DateTime @default(now())

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
}

model ChannelInvite {
  id         String   @id @default(uuid())
  channelId  String
  inviterId  String
  inviteeId  String
  createdAt  DateTime @default(now())

  channel    Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  inviter    User    @relation("ChannelInvitesSent", fields: [inviterId], references: [id], onDelete: Restrict)
  invitee    User    @relation("ChannelInvitesReceived", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId])
  @@unique([channelId, inviteeId])
}

model ChannelMessage {
  id        String   @id @default(uuid())
  channelId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  // Threading: root messages have threadRootId = null; replies set threadRootId to the root message id.
  threadRootId String?
  threadRoot   ChannelMessage? @relation("ChannelThreadRoot", fields: [threadRootId], references: [id], onDelete: Cascade)
  threadReplies ChannelMessage[] @relation("ChannelThreadRoot")

  // Optional direct reply-to (for display / context).
  replyToId String?
  replyTo   ChannelMessage? @relation("ChannelReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChannelMessage[] @relation("ChannelReplyTo")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User    @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([channelId, createdAt])
  @@index([threadRootId, createdAt])
}

