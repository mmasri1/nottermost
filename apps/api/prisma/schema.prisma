generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String             @id @default(uuid())
  email        String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())

  memberships  WorkspaceMember[]
  sentMessages Message[]
  channelMemberships ChannelMember[]
  sentChannelMessages ChannelMessage[]
  sentChannelInvites  ChannelInvite[] @relation("ChannelInvitesSent")
  receivedChannelInvites ChannelInvite[] @relation("ChannelInvitesReceived")
}

model Workspace {
  id        String             @id @default(uuid())
  name      String
  createdAt DateTime           @default(now())

  members   WorkspaceMember[]
  threads   DirectThread[]
  channels  Channel[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}

model DirectThread {
  id          String    @id @default(uuid())
  workspaceId String
  userAId     String
  userBId     String
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([workspaceId])
  @@unique([workspaceId, userAId, userBId])
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  thread    DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([threadId, createdAt])
}

model Channel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     ChannelMember[]
  invites     ChannelInvite[]
  messages    ChannelMessage[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model ChannelMember {
  channelId String
  userId    String
  role      String
  createdAt DateTime @default(now())

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
}

model ChannelInvite {
  id         String   @id @default(uuid())
  channelId  String
  inviterId  String
  inviteeId  String
  createdAt  DateTime @default(now())

  channel    Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  inviter    User    @relation("ChannelInvitesSent", fields: [inviterId], references: [id], onDelete: Restrict)
  invitee    User    @relation("ChannelInvitesReceived", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId])
  @@unique([channelId, inviteeId])
}

model ChannelMessage {
  id        String   @id @default(uuid())
  channelId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User    @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([channelId, createdAt])
}

